# PostgreSQL connection string
# Use Timeweb Cloud DBaaS or external PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT secret key (min 32 characters)
JWT_SECRET=YourSuperSecretKeyThatShouldBeAtLeast32CharactersLong!

# CORS allowed origins (not needed with nginx proxy, but kept for direct backend access)
ALLOWED_ORIGINS=*
